# Backend port
PORT=3000

# Postgres connection
# Local:    postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase: use the Transaction pooler URL (port 6543) for the running app.
#           Append ?pgbouncer=true&connection_limit=1 for serverless safety.
# URL-encode special characters in the password (& → %26, * → %2A, etc.).
DATABASE_URL=

# Supabase only: direct connection (port 5432) used by `prisma migrate`.
# Leave empty for local Postgres.
DIRECT_URL=

# Supabase Storage (PDF bytes live here)
# Dashboard → Settings → API for URL + service_role key.
# service_role bypasses RLS — server only, NEVER expose to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cuebites-esign

# Long random string. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_TTL=7d

# 32-byte hex key used to encrypt secrets at rest (SMTP password etc.).
# MUST be exactly 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Where the Next.js app runs (used by CORS + cookie origin)
CORS_ORIGIN=http://localhost:3001

# Cookie
COOKIE_NAME=cb_session
# Set "true" in production behind HTTPS
COOKIE_SECURE=false
# "lax" works for localhost:3001 <-> localhost:3000 (same site).
# Use "none" in production if the API lives on a different site.
COOKIE_SAMESITE=lax
